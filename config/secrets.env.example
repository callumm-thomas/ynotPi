# ─────────────────────────────────────────────────────────────
# ynotPi — secrets.env.example
# Copy this file to secrets.env and fill in your real API keys.
# Run scripts/setup_keys.sh to be guided through it interactively.
#
# !! NEVER commit secrets.env to GitHub — it's in .gitignore !!
# ─────────────────────────────────────────────────────────────

# Weather data — https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Crypto prices — https://www.coingecko.com/en/api (free tier needs no key, but pro does)
COINGECKO_API_KEY=

# News headlines — https://newsapi.org
NEWS_API_KEY=

# NASA imagery & APOD — https://api.nasa.gov
NASA_API_KEY=

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Add more keys below as you go — just follow the same format
# MY_NEW_API_KEY=
